# =============================================================================
# Информационная система (универсальная: каталог услуг/товаров, заказы)
# PyQt6 + MySQL, база app_db, порт 3307
# role_id=1 — администратор, role_id=2 — клиент
# Логины: admin/admin123, client/client123
# =============================================================================

import sys, os, shutil, pymysql
from PyQt6.QtWidgets import *
from PyQt6.QtCore import *
from PyQt6.QtGui import *

# --- Подключение к базе данных ---

def ensure_database():
    # Создаёт базу app_db, если её ещё нет
    conn = pymysql.connect(
        host="localhost",
        port=3307,
        user="root",
        password="root",
        cursorclass=pymysql.cursors.DictCursor
    )
    with conn.cursor() as c:
        c.execute("CREATE DATABASE IF NOT EXISTS app_db")
    conn.commit()
    conn.close()


def db():
    # Подключение к MySQL (DictCursor — доступ к полям по имени столбца)
    return pymysql.connect(
        host="localhost",
        port=3307,
        user="root",
        password="root",
        database="app_db",
        cursorclass=pymysql.cursors.DictCursor
    )


class DB:
    def __init__(self):
        ensure_database()
        self.conn = db()
        self.init_db()

    def init_db(self):
        # Создание таблиц и тестовых данных при первом запуске
        with self.conn.cursor() as c:
            c.execute("""
                CREATE TABLE IF NOT EXISTS Users (
                    user_id INT PRIMARY KEY AUTO_INCREMENT,
                    username VARCHAR(255) NOT NULL,
                    password_hash VARCHAR(255) NOT NULL,
                    role_id INT NOT NULL
                )
            """)
            c.execute("""
                CREATE TABLE IF NOT EXISTS MenuItems (
                    item_id INT PRIMARY KEY AUTO_INCREMENT,
                    name VARCHAR(255) NOT NULL,
                    price DECIMAL(10,2) NOT NULL,
                    is_available BOOLEAN DEFAULT TRUE,
                    photo VARCHAR(255)
                )
            """)
            c.execute("""
                CREATE TABLE IF NOT EXISTS Orders (
                    order_id INT PRIMARY KEY AUTO_INCREMENT,
                    user_id INT NOT NULL,
                    total DECIMAL(10,2) NOT NULL,
                    created_at DATETIME DEFAULT CURRENT_TIMESTAMP
                )
            """)
            c.execute("""
                CREATE TABLE IF NOT EXISTS OrderItems (
                    order_item_id INT PRIMARY KEY AUTO_INCREMENT,
                    order_id INT NOT NULL,
                    item_id INT NOT NULL,
                    quantity INT NOT NULL,
                    price DECIMAL(10,2) NOT NULL
                )
            """)
            c.execute("SHOW COLUMNS FROM MenuItems LIKE 'photo'")
            if not c.fetchone():
                c.execute("ALTER TABLE MenuItems ADD COLUMN photo VARCHAR(255)")
        self.conn.commit()
        if self.one("SELECT COUNT(*) AS n FROM Users")["n"] == 0:
            # Тестовые пользователи
            self.run(
                "INSERT INTO Users (username, password_hash, role_id) VALUES "
                "('admin', 'admin123', 1), ('client', 'client123', 2)"
            )
        if self.one("SELECT COUNT(*) AS n FROM MenuItems")["n"] == 0:
            # Тестовые позиции каталога (пример: парикмахерская)
            items = [
                ("Стрижка мужская", 500), ("Стрижка женская", 800), ("Стрижка детская", 400),
                ("Борода", 350), ("Окрашивание", 1500), ("Укладка", 600), ("Мелирование", 2000),
                ("Камуфляж седины", 900), ("Выпрямление", 1200), ("Уход за волосами", 450),
            ]
            for name, price_val in items:
                self.run(
                    "INSERT INTO MenuItems (name, price, is_available, photo) VALUES (%s, %s, TRUE, NULL)",
                    (name, price_val)
                )

    def get(self, q, p=None):
        # SELECT — все строки
        with self.conn.cursor() as c:
            c.execute(q, p or ())
            return c.fetchall()

    def one(self, q, p=None):
        # SELECT — одна строка
        with self.conn.cursor() as c:
            c.execute(q, p or ())
            return c.fetchone()

    def run(self, q, p=None):
        # INSERT / UPDATE / DELETE
        with self.conn.cursor() as c:
            c.execute(q, p or ())
            self.conn.commit()

    def save_order(self, uid, items):
        # Сохранение заказа в Orders и OrderItems
        total = sum(i["price"] * i["qty"] for i in items)
        try:
            with self.conn.cursor() as c:
                c.execute("INSERT INTO Orders (user_id, total) VALUES (%s, %s)", (uid, total))
                c.execute("SELECT LAST_INSERT_ID() AS oid")
                oid = c.fetchone()["oid"]
                for i in items:
                    c.execute(
                        "INSERT INTO OrderItems (order_id, item_id, quantity, price) VALUES (%s, %s, %s, %s)",
                        (oid, i["item_id"], i["qty"], i["price"])
                    )
            self.conn.commit()
            return oid, total
        except Exception:
            self.conn.rollback()
            return None, None

# --- Стили интерфейса (белая тема) ---
CSS = """
QMainWindow,QWidget,QDialog,QScrollArea{background:#F5F5F5;color:#212121;border:none}
QLineEdit{background:#FFF;border:1px solid #CCC;border-radius:6px;padding:8px}
QPushButton{background:#FFF;border:1px solid #CCC;border-radius:6px;padding:6px 12px}
QPushButton:hover{background:#EEE}
QPushButton#primaryBtn{background:#0078D7;color:#FFF;border:none;font-weight:bold;padding:10px}
QPushButton#dangerBtn{color:#D32F2F}
QFrame#itemCard{background:#FFF;border:1px solid #E0E0E0;border-radius:10px}
QWidget#headerBar{background:#FFF;border-bottom:1px solid #E0E0E0}
QLabel#cardTitle,QLabel#priceLabel{font-weight:bold}
QLabel#statusOk{color:#388E3C} QLabel#statusOff{color:#D32F2F}
"""

def theme(app):
    # Применяет светлую тему ко всему приложению
    app.setStyle("Fusion")
    app.setStyleSheet(CSS)

def mk_btn(text, fn=None, kind="default"):
    # Создаёт кнопку (default / primary / danger / accent)
    m = {"primary": "primaryBtn", "danger": "dangerBtn", "default": "defaultBtn", "accent": "defaultBtn"}
    b = QPushButton(text); b.setObjectName(m[kind])
    if fn: b.clicked.connect(fn)
    return b

def header(title, buttons):
    # Верхняя панель с заголовком и кнопками
    w = QWidget(); w.setObjectName("headerBar"); w.setFixedHeight(52)
    h = QHBoxLayout(w); h.setContentsMargins(16, 6, 16, 6)
    t = QLabel(title); t.setObjectName("headerTitle"); h.addWidget(t); h.addStretch()
    for txt, fn, k in buttons: h.addWidget(mk_btn(txt, fn, k))
    return w

def card(w=280, h=400):
    # Карточка позиции каталога в сетке
    f = QFrame(); f.setObjectName("itemCard"); f.setFixedSize(w, h)
    l = QVBoxLayout(f); l.setContentsMargins(12, 12, 12, 12); l.setSpacing(6)
    return f, l

def pix(path, w, h):
    # Масштабирование изображения
    return QPixmap(path).scaled(w, h, Qt.AspectRatioMode.KeepAspectRatio, Qt.TransformationMode.SmoothTransformation)

def photo(path, w=260, h=180):
    # Изображение позиции (или заглушка)
    lab = QLabel(); lab.setFixedSize(w, h); lab.setAlignment(Qt.AlignmentFlag.AlignCenter)
    lab.setScaledContents(True)
    lab.setStyleSheet("border:1px dashed #CCC;border-radius:8px;background:#FAFAFA;color:#999")
    if path and os.path.exists(path): lab.setPixmap(pix(path, w, h))
    else: lab.setText("Нет фото")
    return lab

def price(s):
    # Преобразует строку цены в число (точка или запятая)
    s = s.strip().replace(",", ".")
    if not s: raise ValueError
    return float(s)

def clear_grid(grid):
    # Очистка сетки перед перерисовкой
    for i in reversed(range(grid.count())): grid.itemAt(i).widget().deleteLater()

def back_login(login, win):
    # Возврат на экран авторизации
    login.u.clear(); login.p.clear(); login.show(); login.raise_()
    win._out = True; win.close()

# --- Окно входа ---

class Login(QWidget):
    def __init__(self, db):
        super().__init__()
        self.db = db
        self.setWindowTitle("Вход"); self.resize(300, 200)
        l = QVBoxLayout(self)
        l.addWidget(QLabel("Логин:")); self.u = QLineEdit(); l.addWidget(self.u)
        l.addWidget(QLabel("Пароль:")); self.p = QLineEdit()
        self.p.setEchoMode(QLineEdit.EchoMode.Password)  # скрытый ввод пароля
        l.addWidget(self.p)
        l.addWidget(QPushButton("Войти", clicked=self.login))
        l.addWidget(QPushButton("Выход", clicked=lambda: QApplication.instance().quit()))

    def login(self):
        # Проверка логина и пароля, открытие окна по role_id
        u = self.db.one("SELECT * FROM Users WHERE username=%s AND password_hash=%s", (self.u.text(), self.p.text()))
        if not u: return QMessageBox.critical(self, "", "Неверно")
        if u["role_id"] == 1: w = Admin(self.db, u, self)       # администратор
        elif u["role_id"] == 2: w = Client(self.db, u, self)      # клиент
        else: return QMessageBox.critical(self, "", "Неизвестная роль")
        w.show(); self.hide()  # форма входа скрывается, не закрывается

# --- Окно администратора ---

class Admin(QMainWindow):
    def __init__(self, db, user, login):
        super().__init__()
        self.db, self.login, self.sort, self._out = db, login, None, False
        self.setWindowTitle(f"Админ — {user['username']}"); self.resize(960, 600)
        os.makedirs("photos", exist_ok=True)  # папка для фото позиций
        self.grid_w = QWidget(); self.grid = QGridLayout(self.grid_w)
        self.grid.setSpacing(14); self.grid.setContentsMargins(16, 16, 16, 16)
        sc = QScrollArea(); sc.setWidgetResizable(True); sc.setWidget(self.grid_w)
        c = QWidget(); v = QVBoxLayout(c); v.setContentsMargins(0, 0, 0, 0); v.setSpacing(0)
        v.addWidget(header(f"Панель администратора — {user['username']}", [
            ("+ Добавить", self.add_item, "accent"), ("Цена ↑", lambda: self.set_sort("ASC"), "default"),
            ("Цена ↓", lambda: self.set_sort("DESC"), "default"), ("Выход", self.logout, "danger")]))
        v.addWidget(sc); self.setCentralWidget(c); self.load()

    def set_sort(self, o):
        # Сортировка по цене
        self.sort = o; self.load()

    def load(self):
        # Загрузка карточек каталога (3 в ряд)
        clear_grid(self.grid)
        q = "SELECT * FROM MenuItems" + (f" ORDER BY price {self.sort}" if self.sort else "")
        r = c = 0
        for x in self.db.get(q):
            f, l = card()
            l.addWidget(photo(x.get("photo")))
            n = QLabel(x["name"]); n.setObjectName("cardTitle"); l.addWidget(n)
            p = QLabel(f"{x['price']} ₽"); p.setObjectName("priceLabel"); l.addWidget(p)
            st = QLabel("● Доступно" if x["is_available"] else "● Недоступно")
            st.setObjectName("statusOk" if x["is_available"] else "statusOff"); l.addWidget(st)
            h = QHBoxLayout()
            h.addWidget(mk_btn("Изменить", lambda _, i=x["item_id"]: self.edit_item(i)))
            h.addWidget(mk_btn("Удалить", lambda _, i=x["item_id"]: self.del_item(i), "danger"))
            l.addLayout(h); self.grid.addWidget(f, r, c); c += 1
            if c >= 3: c = 0; r += 1

    def del_item(self, iid):
        # Удаление позиции и её фото с диска
        if QMessageBox.question(self, "", "Удалить?") != QMessageBox.StandardButton.Yes: return
        row = self.db.one("SELECT photo FROM MenuItems WHERE item_id=%s", (iid,))
        if row and row.get("photo") and os.path.exists(row["photo"]): os.remove(row["photo"])
        self.db.run("DELETE FROM MenuItems WHERE item_id=%s", (iid,)); self.load()

    def edit_item(self, iid=None):
        # Диалог добавления или редактирования позиции (iid=None — новая запись)
        d = QDialog(self); d.setWindowTitle("Позиция"); d.resize(400, 520); l = QVBoxLayout(d)
        n, p = QLineEdit(), QLineEdit()  # название, цена
        av = QCheckBox("Доступен"); av.setChecked(True)
        ph, prev = None, photo(None, 380, 250)  # ph: None=без изменений, ""=удалено, str=путь

        def pick():
            nonlocal ph
            f, _ = QFileDialog.getOpenFileName(d, "Фото", "", "Images (*.png *.jpg *.jpeg *.bmp *.gif)")
            if f: ph = f; prev.setPixmap(pix(f, 380, 250))

        def rm():
            nonlocal ph; ph = ""; prev.clear(); prev.setText("Нет фото")

        if iid:
            r = self.db.one("SELECT * FROM MenuItems WHERE item_id=%s", (iid,))
            if r:
                n.setText(r["name"]); p.setText(str(r["price"])); av.setChecked(r["is_available"])
                if r.get("photo") and os.path.exists(r["photo"]):
                    ph = r["photo"]; prev.setPixmap(pix(r["photo"], 380, 250))

        for w in [QLabel("Название:"), n, QLabel("Цена:"), p, QLabel("Фото:"), prev,
                  mk_btn("Выбрать фото", pick), mk_btn("Удалить фото", rm, "danger"), av]:
            l.addWidget(w)

        def save():
            try:
                nm, pr = n.text().strip(), price(p.text())
                if not nm: return QMessageBox.critical(d, "", "Введите название")

                def copy_f(tid):
                    # Копирование фото в папку photos/
                    if not ph or ph == "": return None
                    dst = f"photos/{nm.replace(' ','_').replace('/','_')}_{tid}{os.path.splitext(ph)[1] or '.jpg'}"
                    shutil.copy2(ph, dst); return dst

                if iid:
                    # Режим редактирования
                    old = self.db.one("SELECT photo FROM MenuItems WHERE item_id=%s", (iid,))
                    np = None if ph == "" else (copy_f(iid) if ph else (old.get("photo") if old else None))
                    if ph == "" and old and old.get("photo") and os.path.exists(old["photo"]): os.remove(old["photo"])
                    elif ph and old and old.get("photo") and old["photo"] != ph and os.path.exists(old["photo"]):
                        os.remove(old["photo"])
                    self.db.run("UPDATE MenuItems SET name=%s,price=%s,is_available=%s,photo=%s WHERE item_id=%s",
                                (nm, pr, av.isChecked(), np, iid))
                else:
                    # Режим добавления
                    self.db.run("INSERT INTO MenuItems (name,price,is_available,photo) VALUES (%s,%s,%s,NULL)", (nm, pr, av.isChecked()))
                    if ph:
                        tid = self.db.one("SELECT LAST_INSERT_ID() AS item_id")["item_id"]
                        self.db.run("UPDATE MenuItems SET photo=%s WHERE item_id=%s", (copy_f(tid), tid))
                d.accept(); self.load()
            except ValueError: QMessageBox.critical(d, "", "Проверьте цену")
            except Exception as e: QMessageBox.critical(d, "", str(e))

        l.addWidget(mk_btn("Сохранить", save, "primary")); d.exec()

    def add_item(self): self.edit_item()
    def logout(self): back_login(self.login, self)

    def closeEvent(self, e):
        # При закрытии крестиком — возврат на экран входа
        if self.login.isHidden() and not self._out: back_login(self.login, self)
        e.accept()

# --- Окно клиента ---

class Client(QMainWindow):
    def __init__(self, db, user, login):
        super().__init__()
        self.db, self.login, self.user, self.sort, self.cart, self._out = db, login, user, None, {}, False
        self.setWindowTitle(f"Клиент: {user['username']}"); self.resize(900, 550)
        w = QWidget(); self.setCentralWidget(w); v = QVBoxLayout(w)
        h = QHBoxLayout(); self.s = QLineEdit(); self.s.returnPressed.connect(self.search)
        h.addWidget(QLabel("Поиск:")); h.addWidget(self.s)
        # Панель поиска, сортировки и корзины
        for t, fn in [("Найти", self.search), ("Все", lambda: self.load()), ("Цена ↑", lambda: self.set_sort("ASC")),
                      ("Цена ↓", lambda: self.set_sort("DESC"))]: h.addWidget(QPushButton(t, clicked=fn))
        self.cart_btn = QPushButton("Корзина (0)"); self.cart_btn.clicked.connect(self.show_cart); h.addWidget(self.cart_btn)
        h.addWidget(QPushButton("Выход", clicked=self.logout)); v.addLayout(h)
        self.grid_w = QWidget(); self.grid = QGridLayout(self.grid_w)
        sc = QScrollArea(); sc.setWidgetResizable(True); sc.setWidget(self.grid_w); v.addWidget(sc); self.load()

    def cnt(self): return sum(v["qty"] for v in self.cart.values())
    def total(self): return sum(v["price"] * v["qty"] for v in self.cart.values())
    def upd_cart(self): self.cart_btn.setText(f"Корзина ({self.cnt()})")
    def set_sort(self, o): self.sort = o; self.load(self.s.text() or None)
    def search(self): self.load(self.s.text())

    def load(self, s=None):
        # Каталог доступных позиций, фильтр по названию
        clear_grid(self.grid)
        order_sql = f" ORDER BY price {self.sort}" if self.sort else ""
        if s:
            items = self.db.get(f"SELECT * FROM MenuItems WHERE is_available=1 AND name LIKE %s{order_sql}", (f"%{s}%",))
        else:
            items = self.db.get(f"SELECT * FROM MenuItems WHERE is_available=1{order_sql}")
        r = c = 0
        for x in items:
            f, l = card(280, 390)
            l.addWidget(photo(x.get("photo"))); l.addWidget(QLabel(f"<b>{x['name']}</b>"))
            l.addWidget(QLabel(f"Цена: {x['price']} руб"))
            b = QHBoxLayout()
            b.addWidget(QPushButton("Подробнее", clicked=lambda _, i=x["item_id"]: self.detail(i)))
            b.addWidget(QPushButton("В корзину", clicked=lambda _, it=x: self.add_cart(it)))
            l.addLayout(b); self.grid.addWidget(f, r, c); c += 1
            if c >= 3: c = 0; r += 1

    def add_cart(self, item):
        # Добавление в корзину (увеличение qty, если уже есть)
        i = item["item_id"]
        if i in self.cart: self.cart[i]["qty"] += 1
        else: self.cart[i] = {"item_id": i, "name": item["name"], "price": float(item["price"]), "qty": 1}
        self.upd_cart(); QMessageBox.information(self, "", f"«{item['name']}» добавлено в корзину")

    def detail(self, iid):
        # Подробная информация о позиции
        x = self.db.one("SELECT * FROM MenuItems WHERE item_id=%s", (iid,))
        if not x: return
        d = QDialog(self); d.setWindowTitle(x["name"]); l = QVBoxLayout(d)
        if x.get("photo") and os.path.exists(x["photo"]):
            lab = QLabel(); lab.setAlignment(Qt.AlignmentFlag.AlignCenter); lab.setScaledContents(True)
            lab.setPixmap(pix(x["photo"], 400, 300)); l.addWidget(lab)
        l.addWidget(QLabel(f"<b>{x['name']}</b>")); l.addWidget(QLabel(f"Цена: {x['price']} руб"))
        h = QHBoxLayout()
        h.addWidget(QPushButton("В корзину", clicked=lambda: (self.add_cart(x), d.accept())))
        h.addWidget(QPushButton("Закрыть", clicked=d.accept)); l.addLayout(h); d.exec()

    def show_cart(self):
        # Окно корзины: +/- количество, оформление заказа
        d = QDialog(self); d.setWindowTitle("Корзина"); d.resize(520, 480); l = QVBoxLayout(d)
        if not self.cart:
            l.addWidget(QLabel("Корзина пуста")); l.addWidget(QPushButton("Закрыть", clicked=d.accept)); d.exec(); return
        box = QWidget(); bl = QVBoxLayout(box)
        tot = QLabel(f"Итого: {self.total():.0f} руб"); tot.setStyleSheet("font-weight:bold")
        empty = QLabel("Корзина пуста"); empty.hide()

        def ch_qty(i, ql, sl, delta):
            # Изменение количества (+1 или -1)
            if delta < 0 and (i not in self.cart or self.cart[i]["qty"] <= 1): return
            if i not in self.cart: return
            self.cart[i]["qty"] += delta
            ql.setText(str(self.cart[i]["qty"]))
            sl.setText(f"= {self.cart[i]['price']*self.cart[i]['qty']:.0f} руб")
            tot.setText(f"Итого: {self.total():.0f} руб"); self.upd_cart()

        for i, it in list(self.cart.items()):
            row = QFrame(); row.setFrameStyle(QFrame.Shape.Box); rl = QHBoxLayout(row)
            rl.addWidget(QLabel(f"<b>{it['name']}</b>")); rl.addWidget(QLabel(f"{it['price']:.0f} руб"))
            ql = QLabel(str(it["qty"])); ql.setFixedWidth(24); ql.setAlignment(Qt.AlignmentFlag.AlignCenter)
            sl = QLabel(f"= {it['price']*it['qty']:.0f} руб"); btn_row = QHBoxLayout()
            # _ принимает служебный аргумент checked от QPushButton.clicked
            btn_row.addWidget(QPushButton("-", clicked=lambda _, i=i, q=ql, s=sl: ch_qty(i, q, s, -1)))
            btn_row.addWidget(ql)
            btn_row.addWidget(QPushButton("+", clicked=lambda _, i=i, q=ql, s=sl: ch_qty(i, q, s, 1)))
            rl.addLayout(btn_row); rl.addWidget(sl)
            rl.addWidget(QPushButton("Убрать", clicked=lambda _, i=i, r=row: (
                self.cart.pop(i, None), r.deleteLater(), tot.setText(f"Итого: {self.total():.0f} руб"),
                self.upd_cart(), empty.show() if not self.cart else None)))
            bl.addWidget(row)

        sc = QScrollArea(); sc.setWidgetResizable(True); sc.setWidget(box)
        l.addWidget(sc); l.addWidget(tot); l.addWidget(empty)
        h = QHBoxLayout()
        h.addWidget(QPushButton("Очистить", clicked=lambda: (self.cart.clear(), self.upd_cart(), d.accept(), self.show_cart())))
        h.addWidget(QPushButton("Оформить", clicked=lambda: self.checkout(d)))
        h.addWidget(QPushButton("Закрыть", clicked=d.accept)); l.addLayout(h); d.exec()

    def checkout(self, d):
        # Оформление заказа — запись в БД
        oid, t = self.db.save_order(self.user["user_id"], list(self.cart.values()))
        if oid:
            self.cart.clear(); self.upd_cart(); d.accept()
            QMessageBox.information(self, "", f"Заказ №{oid} на {t:.0f} руб!")
        else:
            QMessageBox.critical(self, "", "Ошибка сохранения заказа")

    def logout(self): back_login(self.login, self)

    def closeEvent(self, e):
        if self.login.isHidden() and not self._out: back_login(self.login, self)
        e.accept()

# --- Запуск ---

def main():
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)  # не закрывать приложение при logout
    theme(app)
    w = Login(DB()); w.show(); w.raise_()
    sys.exit(app.exec())

