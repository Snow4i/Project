# =============================================================================
# Информационная система: каталог услуг (парикмахерская)
# PyQt6 + MySQL, база app_db, порт 3307
# role_id=1 — администратор, role_id=2 — клиент, role_id=3 — гость
# Логины: admin/admin123, client/client123, guest/guest (role_id=3); также кнопка «Как гость»
# =============================================================================

import os
import sys
import shutil
import pymysql
from PyQt6.QtWidgets import *
from PyQt6.QtCore import *
from PyQt6.QtGui import *

# Настройки подключения к MySQL (DictCursor — поля по имени столбца)
DB = dict(host="localhost", port=3307, user="root", password="root", database="app_db",
          cursorclass=pymysql.cursors.DictCursor)

# Стили интерфейса — белая тема
CSS = """
QMainWindow,QWidget,QDialog,QScrollArea{background:#F5F5F5;color:#212121}
QLineEdit{background:#FFF;border:1px solid #CCC;border-radius:6px;padding:8px}
QPushButton{background:#FFF;border:1px solid #CCC;border-radius:6px;padding:6px 12px}
QPushButton:hover{background:#EEE}
QPushButton#primaryBtn{background:#0078D7;color:#FFF;border:none;font-weight:bold}
QPushButton#dangerBtn{color:#D32F2F}
QFrame#itemCard{background:#FFF;border:1px solid #E0E0E0;border-radius:10px}
QWidget#headerBar{background:#FFF;border-bottom:1px solid #E0E0E0}
QLabel#cardTitle,QLabel#priceLabel{font-weight:bold}
QLabel#statusOk{color:#388E3C} QLabel#statusOff{color:#D32F2F}
"""

# --- Блок 1. База данных ---

def db(sql, params=(), one=False):
    # Выполняет SQL: SELECT возвращает данные, INSERT/UPDATE/DELETE сохраняет
    try:
        with pymysql.connect(**DB) as con, con.cursor() as cur:
            cur.execute(sql, params)
            if cur.description:  # если это SELECT
                return cur.fetchone() if one else cur.fetchall()
            con.commit()
    except pymysql.err.OperationalError as e:
        if e.args[0] == 2003:
            QMessageBox.critical(None, "Ошибка БД",
                "Не удалось подключиться к MySQL.\nЗапустите MySQL80, порт 3307.")
        raise

def seed_test_data():
    # Тестовые данные в БД (только если таблицы пустые)
    if db("SELECT COUNT(*) AS n FROM Users", one=True)["n"] == 0:
        db("INSERT INTO Users (username, password_hash, role_id) VALUES "
           "('admin', 'admin123', 1), ('client', 'client123', 2), ('guest', 'guest', 3)")
    elif not db("SELECT 1 AS ok FROM Users WHERE username='guest'", one=True):
        db("INSERT INTO Users (username, password_hash, role_id) VALUES ('guest', 'guest', 3)")
    if db("SELECT COUNT(*) AS n FROM MenuItems", one=True)["n"] == 0:
        test_items = [
            ("Стрижка мужская", 500),
            ("Стрижка женская", 800),
            ("Укладка", 600),
        ]
        for name, price in test_items:
            db("INSERT INTO MenuItems (name, price, is_available, photo) VALUES (%s, %s, TRUE, NULL)",
               (name, price))

def init_db():
    # Создание базы, таблиц и тестовых данных (порт из DB, без имени базы — для CREATE DATABASE)
    cfg = {k: v for k, v in DB.items() if k != "database"}
    with pymysql.connect(**cfg) as con:
        with con.cursor() as cur:
            cur.execute("CREATE DATABASE IF NOT EXISTS app_db")
        con.commit()
    tables = [
        # Users — логины и роли (1=админ, 2=клиент, 3=гость)
        """CREATE TABLE IF NOT EXISTS Users (
            user_id INT PRIMARY KEY AUTO_INCREMENT, username VARCHAR(255) NOT NULL,
            password_hash VARCHAR(255) NOT NULL, role_id INT NOT NULL)""",
        # MenuItems — услуги каталога
        """CREATE TABLE IF NOT EXISTS MenuItems (
            item_id INT PRIMARY KEY AUTO_INCREMENT, name VARCHAR(255) NOT NULL,
            price DECIMAL(10,2) NOT NULL, is_available BOOLEAN DEFAULT TRUE, photo VARCHAR(255))""",
    ]
    for sql in tables:
        db(sql)
    seed_test_data()

# --- Блок 2. Помощники интерфейса ---

def btn(text, slot=None, kind="default"):
    # Создаёт кнопку (default / primary / danger / accent)
    styles = {"primary": "primaryBtn", "danger": "dangerBtn", "default": "defaultBtn", "accent": "defaultBtn"}
    b = QPushButton(text)
    b.setObjectName(styles[kind])
    if slot:
        b.clicked.connect(slot)
    return b

def top_bar(title, buttons):
    # Верхняя панель с заголовком и кнопками
    bar = QWidget()
    bar.setObjectName("headerBar")
    bar.setFixedHeight(52)
    row = QHBoxLayout(bar)
    row.setContentsMargins(16, 6, 16, 6)
    row.addWidget(QLabel(title))
    row.addStretch()
    for text, slot, kind in buttons:
        row.addWidget(btn(text, slot, kind))
    return bar

def make_card(w=280, h=400):
    # Белая карточка позиции в сетке
    frame = QFrame()
    frame.setObjectName("itemCard")
    frame.setFixedSize(w, h)
    layout = QVBoxLayout(frame)
    layout.setContentsMargins(12, 12, 12, 12)
    layout.setSpacing(6)
    return frame, layout

def show_photo(path, w=260, h=180):
    # Показывает фото или надпись «Нет фото»
    lab = QLabel()
    lab.setFixedSize(w, h)
    lab.setAlignment(Qt.AlignmentFlag.AlignCenter)
    lab.setScaledContents(True)
    lab.setStyleSheet("border:1px dashed #CCC;border-radius:8px;background:#FAFAFA;color:#999")
    if path and os.path.exists(path):
        lab.setPixmap(QPixmap(path).scaled(w, h, Qt.AspectRatioMode.KeepAspectRatio))
    else:
        lab.setText("Нет фото")
    return lab

def clear_grid(grid):
    # Очищает сетку перед перерисовкой карточек
    for i in reversed(range(grid.count())):
        grid.itemAt(i).widget().deleteLater()

def back_login(login, win):
    # Возврат на экран авторизации
    login.user.clear()
    login.pwd.clear()
    login.show()
    win._out = True  # чтобы closeEvent не сработал дважды
    win.close()

# --- Блок 3. Окно входа ---

class Login(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Вход")
        self.resize(300, 240)
        box = QVBoxLayout(self)
        box.addWidget(QLabel("Логин:"))
        self.user = QLineEdit()
        box.addWidget(self.user)
        box.addWidget(QLabel("Пароль:"))
        self.pwd = QLineEdit()
        self.pwd.setEchoMode(QLineEdit.EchoMode.Password)  # скрытый ввод пароля
        box.addWidget(self.pwd)
        box.addWidget(btn("Войти", self.auth))
        box.addWidget(btn("Как гость", self.as_guest))
        box.addWidget(btn("Выход", QApplication.instance().quit))

    def as_guest(self):
        # Вход без пароля — просмотр каталога (как в примере с rental_service)
        u = {"username": "Гость", "role_id": 3}
        w = Client(u, self)
        w.show()
        self.hide()

    def auth(self):
        # Проверка логина и пароля, открытие окна по role_id
        try:
            u = db("SELECT * FROM Users WHERE username=%s AND password_hash=%s",
                   (self.user.text(), self.pwd.text()), one=True)
        except pymysql.err.OperationalError:
            return
        if not u:
            QMessageBox.warning(self, "Ошибка", "Неверный логин или пароль")
            return
        if u["role_id"] == 1:
            w = Admin(u, self)       # администратор
        elif u["role_id"] in (2, 3):
            w = Client(u, self)      # клиент или гость
        else:
            QMessageBox.warning(self, "Ошибка", "Неизвестная роль")
            return
        w.show()
        self.hide()  # не close — чтобы можно было вернуться

# --- Блок 4. Окно администратора ---

class Admin(QMainWindow):
    def __init__(self, user, login):
        super().__init__()
        self.login = login
        self.sort = None      # ASC или DESC для сортировки по цене
        self._out = False
        self.setWindowTitle("Админ — " + user["username"])
        self.resize(960, 600)
        os.makedirs("photos", exist_ok=True)  # папка для фото

        # Сетка карточек внутри прокрутки
        self.grid_w = QWidget()
        self.grid = QGridLayout(self.grid_w)
        self.grid.setSpacing(14)
        self.grid.setContentsMargins(16, 16, 16, 16)
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setWidget(self.grid_w)

        page = QWidget()
        layout = QVBoxLayout(page)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)
        layout.addWidget(top_bar("Панель администратора — " + user["username"], [
            ("+ Добавить", self.add, "accent"),
            ("Цена ↑", lambda: self.set_sort("ASC"), "default"),
            ("Цена ↓", lambda: self.set_sort("DESC"), "default"),
            ("Выход", self.logout, "danger"),
        ]))
        layout.addWidget(scroll)
        self.setCentralWidget(page)
        self.load()

    def set_sort(self, order):
        # Сортировка по цене
        self.sort = order
        self.load()

    def load(self):
        # Загрузка карточек из БД (3 в ряд)
        clear_grid(self.grid)
        sql = "SELECT * FROM MenuItems"
        if self.sort:
            sql += f" ORDER BY price {self.sort}"
        row = col = 0
        for item in db(sql):
            frame, box = make_card()
            box.addWidget(show_photo(item.get("photo")))
            name = QLabel(item["name"])
            name.setObjectName("cardTitle")
            box.addWidget(name)
            price = QLabel(str(item["price"]) + " ₽")
            price.setObjectName("priceLabel")
            box.addWidget(price)
            if item["is_available"]:
                st = QLabel("● Доступно")
                st.setObjectName("statusOk")
            else:
                st = QLabel("● Недоступно")
                st.setObjectName("statusOff")
            box.addWidget(st)
            btns = QHBoxLayout()
            iid = item["item_id"]
            # checked=False — PyQt передаёт этот аргумент при clicked
            btns.addWidget(btn("Изменить", lambda checked=False, x=iid: self.edit(x)))
            btns.addWidget(btn("Удалить", lambda checked=False, x=iid: self.delete(x), "danger"))
            box.addLayout(btns)
            self.grid.addWidget(frame, row, col)
            col += 1
            if col == 3:
                col = 0
                row += 1

    def delete(self, item_id):
        # Удаление позиции и её фото с диска
        if QMessageBox.question(self, "", "Удалить?") != QMessageBox.StandardButton.Yes:
            return
        row = db("SELECT photo FROM MenuItems WHERE item_id=%s", (item_id,), one=True)
        if row and row.get("photo") and os.path.exists(row["photo"]):
            os.remove(row["photo"])
        db("DELETE FROM MenuItems WHERE item_id=%s", (item_id,))
        self.load()

    def add(self):
        self.edit(None)

    def edit(self, item_id):
        # Диалог добавления или редактирования (item_id=None — новая запись)
        dialog = QDialog(self)
        dialog.setWindowTitle("Позиция")
        dialog.resize(400, 520)
        box = QVBoxLayout(dialog)
        name = QLineEdit()
        price = QLineEdit()
        available = QCheckBox("Доступен")
        available.setChecked(True)
        preview = show_photo(None, 380, 250)
        photo_path = [None]  # список, чтобы менять значение во вложенных функциях

        if item_id:
            item = db("SELECT * FROM MenuItems WHERE item_id=%s", (item_id,), one=True)
            if item:
                name.setText(item["name"])
                price.setText(str(item["price"]))
                available.setChecked(item["is_available"])
                if item.get("photo") and os.path.exists(item["photo"]):
                    photo_path[0] = item["photo"]
                    preview.setPixmap(QPixmap(item["photo"]).scaled(380, 250, Qt.AspectRatioMode.KeepAspectRatio))

        def pick():
            # Выбор нового фото с диска
            path, _ = QFileDialog.getOpenFileName(dialog, "Фото", "", "Images (*.png *.jpg *.jpeg *.bmp *.gif)")
            if path:
                photo_path[0] = path
                preview.setPixmap(QPixmap(path).scaled(380, 250, Qt.AspectRatioMode.KeepAspectRatio))

        def remove():
            photo_path[0] = ""  # пустая строка = фото удалено
            preview.clear()
            preview.setText("Нет фото")

        for w in [QLabel("Название:"), name, QLabel("Цена:"), price, QLabel("Фото:"), preview,
                  btn("Выбрать фото", pick), btn("Удалить фото", remove, "danger"), available]:
            box.addWidget(w)

        def save():
            nm = name.text().strip()
            if not nm:
                QMessageBox.warning(dialog, "Ошибка", "Введите название")
                return
            try:
                pr = float(price.text().replace(",", "."))
            except ValueError:
                QMessageBox.warning(dialog, "Ошибка", "Проверьте цену")
                return

            def copy_photo(target_id):
                # Копирует фото в папку photos/
                if not photo_path[0] or photo_path[0] == "":
                    return None
                ext = os.path.splitext(photo_path[0])[1] or ".jpg"
                dst = f"photos/{nm.replace(' ','_')}_{target_id}{ext}"
                shutil.copy2(photo_path[0], dst)
                return dst

            if item_id:
                # Режим редактирования
                old = db("SELECT photo FROM MenuItems WHERE item_id=%s", (item_id,), one=True)
                new_photo = old.get("photo") if old else None
                if photo_path[0] == "":
                    new_photo = None
                    if old and old.get("photo") and os.path.exists(old["photo"]):
                        os.remove(old["photo"])
                elif photo_path[0]:
                    new_photo = copy_photo(item_id)
                db("UPDATE MenuItems SET name=%s,price=%s,is_available=%s,photo=%s WHERE item_id=%s",
                   (nm, pr, available.isChecked(), new_photo, item_id))
            else:
                # Режим добавления
                db("INSERT INTO MenuItems (name,price,is_available,photo) VALUES (%s,%s,%s,NULL)",
                   (nm, pr, available.isChecked()))
                new_id = db("SELECT LAST_INSERT_ID() AS id", one=True)["id"]
                if photo_path[0]:
                    db("UPDATE MenuItems SET photo=%s WHERE item_id=%s", (copy_photo(new_id), new_id))
            dialog.accept()
            self.load()

        box.addWidget(btn("Сохранить", save, "primary"))
        dialog.exec()

    def logout(self):
        back_login(self.login, self)

    def closeEvent(self, e):
        # При закрытии крестиком — возврат на экран входа
        if self.login.isHidden() and not self._out:
            back_login(self.login, self)
        e.accept()

# --- Блок 5. Окно клиента ---

class Client(QMainWindow):
    def __init__(self, user, login):
        super().__init__()
        self.login = login
        self.sort = None
        self._out = False
        role = user["role_id"]
        title = "Гость — каталог" if role == 3 else "Клиент: " + user["username"]
        self.setWindowTitle(title)
        self.resize(900, 550)

        page = QWidget()
        layout = QVBoxLayout(page)
        # Панель поиска и сортировки
        top = QHBoxLayout()
        self.search = QLineEdit()
        self.search.returnPressed.connect(self.do_search)
        top.addWidget(QLabel("Поиск:"))
        top.addWidget(self.search)
        top.addWidget(btn("Найти", self.do_search))
        top.addWidget(btn("Все", lambda: self.load()))
        top.addWidget(btn("Цена ↑", lambda: self.set_sort("ASC")))
        top.addWidget(btn("Цена ↓", lambda: self.set_sort("DESC")))
        top.addWidget(btn("Выход", self.logout))
        layout.addLayout(top)

        self.grid_w = QWidget()
        self.grid = QGridLayout(self.grid_w)
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setWidget(self.grid_w)
        layout.addWidget(scroll)
        self.setCentralWidget(page)
        self.load()

    def set_sort(self, order):
        self.sort = order
        self.load(self.search.text().strip() or None)

    def do_search(self):
        self.load(self.search.text().strip() or None)

    def load(self, text=None):
        # Каталог доступных позиций, фильтр по названию
        clear_grid(self.grid)
        order = f" ORDER BY price {self.sort}" if self.sort else ""
        if text:
            items = db("SELECT * FROM MenuItems WHERE is_available=1 AND name LIKE %s" + order, ("%" + text + "%",))
        else:
            items = db("SELECT * FROM MenuItems WHERE is_available=1" + order)
        row = col = 0
        for item in items:
            frame, box = make_card(280, 390)
            box.addWidget(show_photo(item.get("photo")))
            box.addWidget(QLabel("<b>" + item["name"] + "</b>"))
            box.addWidget(QLabel("Цена: " + str(item["price"]) + " руб"))
            btns = QHBoxLayout()
            iid = item["item_id"]
            btns.addWidget(btn("Подробнее", lambda checked=False, x=iid: self.detail(x)))
            box.addLayout(btns)
            self.grid.addWidget(frame, row, col)
            col += 1
            if col == 3:
                col = 0
                row += 1

    def detail(self, item_id):
        # Подробная информация о позиции
        item = db("SELECT * FROM MenuItems WHERE item_id=%s", (item_id,), one=True)
        if not item:
            return
        dialog = QDialog(self)
        dialog.setWindowTitle(item["name"])
        box = QVBoxLayout(dialog)
        if item.get("photo") and os.path.exists(item["photo"]):
            photo = QLabel()
            photo.setAlignment(Qt.AlignmentFlag.AlignCenter)
            photo.setScaledContents(True)
            photo.setPixmap(QPixmap(item["photo"]).scaled(400, 300, Qt.AspectRatioMode.KeepAspectRatio))
            box.addWidget(photo)
        box.addWidget(QLabel("<b>" + item["name"] + "</b>"))
        box.addWidget(QLabel("Цена: " + str(item["price"]) + " руб"))
        box.addWidget(btn("Закрыть", dialog.accept))
        dialog.exec()

    def logout(self):
        back_login(self.login, self)

    def closeEvent(self, e):
        if self.login.isHidden() and not self._out:
            back_login(self.login, self)
        e.accept()

# --- Запуск ---

if __name__ == "__main__":
    init_db()
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)  # не закрывать приложение при logout
    app.setStyle("Fusion")
    app.setStyleSheet(CSS)
    win = Login()
    win.show()
    sys.exit(app.exec())

